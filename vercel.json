{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist/client",
    "functions": {
        "api/index.js": {
            "includeFiles": "dist/server/**"
        }
    },
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ]
}